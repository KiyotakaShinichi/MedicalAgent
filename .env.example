GROQ_API_KEY=replace_with_your_groq_key
GROQ_ANSWER_MODEL=openai/gpt-oss-120b
GROQ_ROUTER_MODEL=llama-3.3-70b-versatile
GROQ_ADJUDICATION_TIMEOUT_SECONDS=3
LLM_ADJUDICATION_ENABLED=true

# Optional local app settings
APP_ENV=development
DATABASE_URL=sqlite:///./medical_agent.db
SQLITE_TIMEOUT_SECONDS=30

# Docker Compose overrides DATABASE_URL with Postgres automatically.
# For manual Postgres runs:
# DATABASE_URL=postgresql+psycopg2://medical_agent:medical_agent@127.0.0.1:5432/medical_agent
REDIS_URL=redis://127.0.0.1:6379/0

# Optional RAG reranking. Disabled by default because first run downloads a model.
RAG_ENABLE_CROSS_ENCODER=false
RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Optional MLflow mirroring. The local JSON/DB registry works without MLflow.
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=file:./Data/mlruns_mlflow

# Optional local Ollama fallback/learning sandbox.
# Groq is primary when GROQ_API_KEY is set; Ollama is for local experiments or fallback only.
# Leave OLLAMA_MODEL blank to skip Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SECONDS=3

# Never commit real API keys or patient data.
