GROQ_API_KEY=replace_with_your_groq_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_ADJUDICATION_TIMEOUT_SECONDS=3
LLM_ADJUDICATION_ENABLED=true

# Optional local app settings
APP_ENV=development
DATABASE_URL=sqlite:///./medical_agent.db

# Optional local Ollama fallback/learning sandbox.
# Groq is primary when GROQ_API_KEY is set; Ollama is for local experiments or fallback only.
# Leave OLLAMA_MODEL blank to skip Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SECONDS=3

# Never commit real API keys or patient data.
